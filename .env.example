# metainflow-studio-cli 环境变量配置模版
# 复制为 .env 并填入实际值：cp .env.example .env

# ── LLM Provider ──────────────────────────────────────────────────────────────

# OpenAI 兼容接口地址（默认指向 OpenAI 官方，可替换为其他兼容服务）
# 如果要启用 search-summary 的智谱主搜索链路，可改为：
# https://open.bigmodel.cn/api/paas/v4
PROVIDER_BASE_URL=https://api.openai.com/v1

# API 密钥（必填）
PROVIDER_API_KEY=sk-...

# 单次请求超时秒数
PROVIDER_TIMEOUT_SECONDS=60

# 失败后最大重试次数
PROVIDER_MAX_RETRIES=2

# ── 模型选择 ──────────────────────────────────────────────────────────────────

# parse-doc 命令使用的模型
PROVIDER_MODEL_DOC_PARSE=gpt-4.1-mini

# search-summary 命令的 provider 搜索模型占位配置（当前运行时未直接使用）
PROVIDER_MODEL_WEB_SEARCH=glm-4-air

# web-crawl 命令使用的模型
PROVIDER_MODEL_WEB_FETCH=gpt-4.1-mini

# search-summary 总结阶段可单独覆盖端点与密钥；未设置时回退到 PROVIDER_*
# SUMMARY_BASE_URL=https://api.openai.com/v1
# SUMMARY_API_KEY=sk-...
SUMMARY_MODEL=glm-4-flash

# ── 测试开关 ──────────────────────────────────────────────────────────────────

# 设为 1 时启用真实样本矩阵集成测试（默认跳过）
# METAINFLOW_RUN_SAMPLE_MATRIX=1

# ── Web Fetch ────────────────────────────────────────────────────────────────

# web-crawl 抓取是否校验 SSL（默认开启，设为 0 可跳过校验）
METAINFLOW_WEB_FETCH_VERIFY_SSL=1

# ── Web Search ───────────────────────────────────────────────────────────────

# search-summary 中 Baidu Playwright fallback 的页面超时
SEARCH_PAGE_TIMEOUT_SECONDS=30

# 可选：auto / zhipu-web-search / searxng-web-search / baidu-playwright
WEB_SEARCH_BACKEND=auto

# 智谱 provider 搜索档位
SEARCH_PROVIDER_ENGINE=search_pro

# 搜索结果数量
SEARCH_RESULT_COUNT=10

# SearXNG fallback 地址
SEARXNG_BASE_URL=http://localhost:8080
